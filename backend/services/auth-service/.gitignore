target/

# Exclude JAR/WAR files
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# Maven wrapper - keep required files for reproducible builds
!.mvn/
!.mvn/wrapper/
!.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties

.idea/
*.iml
*.iws
*.ipr

.vscode/
.settings/
.project
.classpath

application-local.yml
application-*.yml
!application.yml
!application-dev.yml
!src/test/resources/application-test.yml
